# ═══════════════════════════════════════════════════════════════════════════════
# Claim Pilot — Backend (FastAPI gateway)
# ═══════════════════════════════════════════════════════════════════════════════
# Copy to .env in this directory:  cp env.example .env
#
# WARNING: Never commit .env to version control!
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────────────────────
APP_NAME=Claim Pilot
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────
# AWS (optional — prefer ~/.aws/credentials or IAM role)
# Used by boto3 if you add Bedrock/S3 calls from the gateway later.
# ─────────────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_KNOWLEDGE_BASE_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Data stores
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/claim_pilot
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────────────────────────────────────
# Upstream AI service — URL must be reachable FROM wherever the backend runs:
# - Backend on host (make run):        http://localhost:9020
# - Backend in Docker (make docker-run): http://host.docker.internal:9020
# - Backend in compose (same stack):   http://ai-service:9020  (compose sets this)
# ─────────────────────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:9020

# ─────────────────────────────────────────────────────────────────────────────
# GitHub — PAT with read access to claim-pilot-core and claim-pilot-logging (if private)
# Same pattern as aims-api: Makefile loads .env and passes GITHUB_TOKEN to docker build.
# Docker build always uses https://x-access-token:TOKEN@github.com/ (matches GitHub HTTPS Git docs).
# Common mistake: OAuth tokens start with gho_ — if you see ho_ in errors, add the missing g in .env.
# Local pip:  git config --global url."https://x-access-token:${GITHUB_TOKEN}@github.com/".insteadOf "https://github.com/"
# Workspace docker compose: set GITHUB_TOKEN in claims-pilot-agent/.env (compose build-arg).
# CI: optional repo secret PIP_GITHUB_TOKEN overrides GITHUB_TOKEN for pip git deps.
# ─────────────────────────────────────────────────────────────────────────────
# GITHUB_TOKEN=
