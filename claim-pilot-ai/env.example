# ═══════════════════════════════════════════════════════════════════════════════
# Claim Pilot — AI service (workflows, DSPy, Bedrock, MCP client)
# ═══════════════════════════════════════════════════════════════════════════════
# Copy to .env in this directory:  cp env.example .env
#
# WARNING: Never commit .env to version control!
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────
# AWS — Bedrock / LiteLLM / boto3 default chain
# ─────────────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_KNOWLEDGE_BASE_ID=

# ─────────────────────────────────────────────────────────────────────────────
# MCP — URL must be reachable FROM wherever the AI service runs:
# - AI on host (make run):              http://localhost:8001
# - AI in Docker (host MCP):            http://host.docker.internal:8001
# - AI in compose (same stack):         http://mcp-server:8001  (compose sets this)
# ─────────────────────────────────────────────────────────────────────────────
MCP_SERVER_URL=http://localhost:8001

# ─────────────────────────────────────────────────────────────────────────────
# Docling (optional extra)
# ─────────────────────────────────────────────────────────────────────────────
DOCLING_ENABLED=false
DOCLING_MAX_CHARS=12000

# ─────────────────────────────────────────────────────────────────────────────
# DSPy + Bedrock (LiteLLM)
# ─────────────────────────────────────────────────────────────────────────────
DSPY_BEDROCK_ENABLED=false
DSPY_MAX_TOKENS=1024

# ─────────────────────────────────────────────────────────────────────────────
# LiteLLM / OpenAI (optional — for eval or non-Bedrock judges)
# ─────────────────────────────────────────────────────────────────────────────
LITELLM_MODEL_ID=
# OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Eval (Ragas / DeepEval)
# ─────────────────────────────────────────────────────────────────────────────
# EVAL_LLM_MODEL=bedrock/anthropic.claude-3-haiku-20240307-v1:0
RUN_EVAL_TESTS=

# ─────────────────────────────────────────────────────────────────────────────
# GitHub — PAT for private git deps (see claim-pilot-backend/env.example)
# ─────────────────────────────────────────────────────────────────────────────
# GITHUB_TOKEN=
